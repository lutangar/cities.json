{
  "name": "cities.json",
  "version": "1.1.59",
  "description": "Cities of the world in Json based on GeoNames Gazetteer",
  "main": "cities.json",
  "types": "cities.d.ts",
  "exports": {
    ".": {
      "types": "./cities.d.ts",
      "default": "./cities.json"
    },
    "./cities.json": {
      "types": "./cities.d.ts",
      "default": "./cities.json"
    },
    "./admin1": {
      "types": "./admin1.d.ts",
      "default": "./admin1.json"
    },
    "./admin2": {
      "types": "./admin2.d.ts",
      "default": "./admin2.json"
    },
    "./admin1.json": {
      "types": "./admin1.d.ts",
      "default": "./admin1.json"
    },
    "./admin2.json": {
      "types": "./admin2.d.ts",
      "default": "./admin2.json"
    }
  },
  "scripts": {
    "test": "node test",
    "convert": "node convert",
    "download": "node download",
    "build": "npm run download && npm run convert",
    "prettier": "prettier -w -u .",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lutangar/cities.json.git"
  },
  "keywords": [
    "cities",
    "json"
  ],
  "author": "lutangar",
  "license": "CC-BY-4.0",
  "bugs": {
    "url": "https://github.com/lutangar/cities.json/issues"
  },
  "homepage": "https://github.com/lutangar/cities.json#readme",
  "devDependencies": {
    "prettier": "^2.7.1",
    "release-it": "^19.2.4",
    "yauzl": "^2.10.0"
  }
}
